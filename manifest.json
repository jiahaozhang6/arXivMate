{
  "manifest_version": 3,
  "name": "arXivMate",
  "description": "A local-first Chromium extension for reading, chatting with, and reviewing arXiv, ACM, IEEE, and PDF papers using your own LLMs.",
  "version": "0.1.19",
  "key": "",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "unlimitedStorage"
  ],
  "optional_permissions": [
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "arXivMate",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*"
      ],
      "js": [
        "i18n.js",
        "update-banner.js",
        "vendor/markdown-it/markdown-it.min.js",
        "vendor/katex/katex.min.js",
        "vendor/pdfjs/pdf.js",
        "math-render.js",
        "markdown-render.js",
        "zotero-client.js",
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.deepseek.com/*"
      ],
      "js": [
        "webchat-injected.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.deepseek.com/*"
      ],
      "js": [
        "webchat.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content.css",
        "i18n.js",
        "update-banner.js",
        "vendor/markdown-it/markdown-it.min.js",
        "vendor/katex/katex.min.js",
        "vendor/katex/katex.min.css",
        "vendor/katex/fonts/*",
        "math-render.js",
        "markdown-render.js",
        "content.js",
        "zotero-client.js",
        "webchat-injected.js",
        "webchat.js",
        "panel.html",
        "vendor/pdfjs/pdf.js",
        "vendor/pdfjs/pdf.worker.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
